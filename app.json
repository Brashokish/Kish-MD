{
"name": "Kish-MD",
"description": "Kish-MD is a fast WhatsApp Multi-Device bot built with Node.js and Baileys.",
"website": "https://github.com/Brashokish/Kish-MD",
"repository": "https://github.com/Brashokish/Kish-MD.git",

"env": {
"SESSION": {
"description": "Paste your WhatsApp session ID after pairing the bot.",
"required": true
},


"OWNER_NUMBER": {
  "description": "Owner WhatsApp number without + (example: 254735905972).",
  "required": true
},

"BOT_NAME": {
  "description": "Name of your bot.",
  "required": false,
  "value": "Kish-MD"
},

"PREFIX": {
  "description": "Command prefix for the bot.",
  "required": true,
  "value": "!"
},

"MODE": {
  "description": "Bot mode: public or private.",
  "required": true,
  "value": "public"
}


},

"buildpacks": [
{
"url": "https://github.com/heroku/heroku-buildpack-apt"
},
{
"url": "https://github.com/clhuang/heroku-buildpack-webp-binaries.git"
},
{
"url": "heroku/nodejs"
},
{
"url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest"
}
],

"formation": {
"worker": {
"quantity": 1,
"size": "eco"
}
}
}
